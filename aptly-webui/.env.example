# Aptly Web UI Configuration

# Port for the web UI
APTLY_WEBUI_PORT=8080

# Path to aptly root directory
APTLY_ROOT_DIR=/var/lib/aptly

# Path to aptly config file
APTLY_CONFIG=/etc/aptly.conf

# Path to GPG home directory
GPG_HOME=~/.gnupg

# Ubuntu ESM token (optional, required for ESM mirroring)
ESM_TOKEN=

# Aptly CLI command or path
APTLY_CLI=aptly
