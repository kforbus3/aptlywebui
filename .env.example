# Copy to .env and adjust before deploying.

# Signing secret for JWT sessions — generate a strong random value:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-this-to-a-long-random-string

# Initial admin account, seeded on first start. CHANGE THE PASSWORD after login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# URL of the aptly REST API (the compose file sets this automatically).
# APTLY_API_URL=http://aptly:8080

# Host port the bundled repo server (nginx) serves published repos on, for apt
# clients. Change if port 80 is already in use on the host; clients then use
# http://<host>:<port>/ in their sources.list.
# REPO_HTTP_PORT=80

# --- Optional TLS front (Caddy) ---
# Only used with the TLS overlay:
#   docker compose -f docker-compose.yml -f docker-compose.tls.yml up -d
# Two DNS names pointing at this host — one for the management UI, one for the
# apt repository. Caddy obtains Let's Encrypt certificates for both and serves
# HTTPS on 443 (redirecting HTTP on 80). For a quick local HTTPS trial without
# DNS, use *.localhost names (Caddy signs them with its own internal CA):
#   WEBUI_DOMAIN=webui.localhost
#   REPO_DOMAIN=repo.localhost
# WEBUI_DOMAIN=aptly.example.com
# REPO_DOMAIN=repo.example.com
